---
import BaseLayout from '../../layouts/BaseLayout.astro';

const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL || 'https://zgtlwyjcxmmhicsccjhd.supabase.co';
const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || 'sb_publishable_fqyImmzqflidAOjs-S4IrQ_Q0yg1Prr';

// Vibes must match the Flutter app exactly
const vibes = [
  { id: 'culture',   label: 'Culture',     emoji: '🏛️', desc: 'Art, history, food scenes' },
  { id: 'city',      label: 'City Break',  emoji: '🌆', desc: 'Streets, cafés, energy' },
  { id: 'beach',     label: 'Beach',       emoji: '🏖️', desc: 'Sun, sea, zero plans' },
  { id: 'food',      label: 'Food & Drink',emoji: '🍜', desc: 'Markets, restaurants, wine' },
  { id: 'party',     label: 'Party',       emoji: '🎉', desc: 'Nightlife, music, chaos' },
  { id: 'adventure', label: 'Adventure',   emoji: '🏔️', desc: 'Hikes, thrills, outdoors' },
  { id: 'nature',    label: 'Nature',      emoji: '🌿', desc: 'Forests, escape' },
  { id: 'wellness',  label: 'Wellness',    emoji: '🧘', desc: 'Spas, slow mornings' },
];

const emojis = ['😎','🌸','🔥','🌊','✨','⚡','🦋','🎯','🌙','🎨','🦊','🐬'];
---

<BaseLayout title="Join the trip — TripSquad" description="Your squad is planning a trip. Fill in your preferences.">

<main class="join-main">
  <div class="container">

    <!-- Loading state -->
    <div id="loading" class="join-loading">
      <div class="join-logo">✈️</div>
      <p>Loading trip details...</p>
    </div>

    <!-- Error state -->
    <div id="error" class="join-error" style="display:none;">
      <div class="join-logo">😕</div>
      <h1>Link not found</h1>
      <p id="error-msg">This invite link may have expired or is invalid.</p>
      <a href="/" class="join-btn">Learn about TripSquad</a>
    </div>

    <!-- Form -->
    <div id="form-container" style="display:none;">

      <!-- Header -->
      <div class="join-header">
        <div class="join-logo">✈️</div>
        <h1 id="trip-name" class="join-title">Loading...</h1>
        <p class="join-sub">Fill this in so the squad can plan around you. Takes about 60 seconds.</p>
        <div class="join-badge">🔒 Anonymous — nobody sees your budget</div>
      </div>

      <!-- Progress -->
      <div class="join-progress">
        <div class="join-progress-bar" id="progress-bar" style="width:20%"></div>
      </div>
      <p class="join-step-label" id="step-label">Step 1 of 5</p>

      <!-- Step 1: Nickname + Emoji -->
      <div class="join-step" id="step-1">
        <h2>What should we call you?</h2>
        <input type="text" id="nickname" class="join-input" placeholder="Your name or nickname" maxlength="20" autofocus />
        <h3>Pick your avatar</h3>
        <div class="join-emoji-grid" id="emoji-grid">
          {emojis.map((e, i) => (
            <button class={`join-emoji-btn${i === 0 ? ' selected' : ''}`} data-emoji={e} type="button">{e}</button>
          ))}
        </div>
      </div>

      <!-- Step 2: Budget -->
      <div class="join-step" id="step-2" style="display:none;">
        <h2>What is your budget per person?</h2>
        <p class="join-hint">This stays anonymous. The squad only sees the group range.</p>
        <div class="join-budget-row">
          <div class="join-budget-field">
            <label>Minimum</label>
            <div class="join-input-wrap">
              <span class="join-currency">$</span>
              <input type="number" id="budget-min" class="join-input join-input-budget" placeholder="500" min="0" />
            </div>
          </div>
          <div class="join-budget-field">
            <label>Maximum</label>
            <div class="join-input-wrap">
              <span class="join-currency">$</span>
              <input type="number" id="budget-max" class="join-input join-input-budget" placeholder="2000" min="0" />
            </div>
          </div>
        </div>
      </div>

      <!-- Step 3: Vibes -->
      <div class="join-step" id="step-3" style="display:none;">
        <h2>What is your vibe?</h2>
        <p class="join-hint">Pick up to 3.</p>
        <div class="join-vibe-grid">
          {vibes.map((v) => (
            <button class="join-vibe-btn" data-vibe={v.id} type="button">
              <span class="join-vibe-emoji">{v.emoji}</span>
              <span class="join-vibe-label">{v.label}</span>
              <span class="join-vibe-desc">{v.desc}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Step 4: Destination preferences -->
      <div class="join-step" id="step-4" style="display:none;">
        <h2>Where do you want to go?</h2>
        <p class="join-hint">Pick from the host's shortlist or suggest your own.</p>
        <div class="join-dest-grid" id="dest-grid">
          <!-- Populated by JS from trip data -->
        </div>
        <div class="join-custom-dest">
          <input type="text" id="custom-dest" class="join-input" placeholder="Suggest a destination..." />
          <button type="button" id="add-dest-btn" class="join-add-btn">+</button>
        </div>
      </div>

      <!-- Step 5: Confirm -->
      <div class="join-step" id="step-5" style="display:none;">
        <h2>Ready to join?</h2>
        <div class="join-summary" id="summary"></div>
      </div>

      <!-- Nav buttons -->
      <div class="join-nav">
        <button type="button" id="back-btn" class="join-btn join-btn-ghost" style="display:none;">← Back</button>
        <button type="button" id="next-btn" class="join-btn join-btn-primary">Next →</button>
      </div>

    </div>

    <!-- Success state -->
    <div id="success" style="display:none;">
      <div class="locked-in">
        <!-- Animated check -->
        <div class="locked-check">
          <svg viewBox="0 0 52 52" class="locked-check-svg">
            <circle cx="26" cy="26" r="25" fill="none" stroke="#CCFF45" stroke-width="2" class="locked-circle"/>
            <path fill="none" stroke="#CCFF45" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M14 27l7 7 16-16" class="locked-path"/>
          </svg>
        </div>

        <h1 class="locked-title">you're locked in 🔒</h1>
        <p class="locked-sub">your vibes are saved. stay here — voting drops when the host is ready.</p>

        <!-- Your preferences as pills -->
        <div class="locked-prefs" id="locked-prefs"></div>

        <!-- Live status -->
        <div class="locked-status">
          <div class="locked-status-inner">
            <div class="locked-pulse"></div>
            <span>waiting for the squad...</span>
          </div>
          <p class="locked-hint">this page auto-updates. no need to refresh.</p>
        </div>

        <!-- App nudge -->
        <div class="locked-app">
          <span>📲</span>
          <div>
            <p class="locked-app-title">want the full experience?</p>
            <p class="locked-app-sub">real-time updates, itineraries, and more</p>
          </div>
          <a href="https://apps.apple.com/app/tripsquad" class="locked-app-btn">get app</a>
        </div>
      </div>
    </div>

    <!-- Voting state -->
    <div id="voting-container" style="display:none;">
      <div class="vote-header">
        <div style="font-size:48px; text-align:center; margin-bottom:12px;">🗳️</div>
        <h1 id="vote-trip-name" class="vote-title">it's decision time</h1>
        <p class="vote-sub">the squad's vibes are in. pick your fave destination.</p>
      </div>

      <div id="vote-nickname-step">
        <h2>First, what is your name?</h2>
        <input type="text" id="vote-nickname" class="join-input" placeholder="Your name or nickname" maxlength="20" />
        <div style="height:16px"></div>
        <button type="button" id="vote-nickname-btn" class="join-btn join-btn-primary" style="width:100%;">Next: See options →</button>
      </div>

      <div id="vote-options" style="display:none;">
        <div id="vote-cards"></div>
        <div style="height:20px"></div>
        <button type="button" id="cast-vote-btn" class="join-btn join-btn-primary" style="width:100%;">Cast my vote ✦</button>
      </div>
    </div>

    <!-- Vote success -->
    <div id="vote-success" style="display:none;">
      <div class="join-success">
        <div class="join-logo" style="font-size:64px;">🎉</div>
        <h1>Vote cast!</h1>
        <p>Your vote has been submitted. The host will reveal the winner soon.</p>
        <a href="/" class="join-btn join-btn-primary" style="margin-top:24px;">Get the TripSquad app</a>
      </div>
    </div>

    <!-- Already revealed -->
    <div id="revealed-container" style="display:none;">
      <div class="join-success">
        <div class="join-logo" style="font-size:64px;">✈️</div>
        <h1 id="revealed-dest">Destination decided!</h1>
        <p>The squad has spoken. Get the app to see the full itinerary.</p>
        <a href="/" class="join-btn join-btn-primary" style="margin-top:24px;">Get the TripSquad app</a>
      </div>
    </div>

  </div>
</main>

</BaseLayout>

<script define:vars={{ SUPABASE_URL, SUPABASE_ANON_KEY }}>
  // State
  let step = 1;
  let tripId = '';
  let tripData = null;
  let selectedEmoji = '😎';
  let selectedVibes = [];
  let selectedDests = [];
  let tripOptions = [];
  let selectedVoteOptionId = null;
  let voteNickname = '';

  const $  = (s) => document.querySelector(s);
  const $$ = (s) => document.querySelectorAll(s);

  // Extract token from query param: /join/?t=abc12345
  const urlParams = new URLSearchParams(window.location.search);
  const token = urlParams.get('t') || '';

  // ── Load trip ──────────────────────────────────────────────
  async function loadTrip() {
    if (!token) {
      showError('No invite token found. Check your link.');
      return;
    }
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/trips?invite_token=eq.${token}&select=id,name,status,vibes,destination_shortlist,selected_destination,selected_flag,created_at,trip_options(id,destination,country,flag,tagline,estimated_cost_pp,duration_days,vibe_match,compatibility_score,vote_count)`,
        { headers: { apikey: SUPABASE_ANON_KEY, Authorization: `Bearer ${SUPABASE_ANON_KEY}` } }
      );
      const data = await res.json();

      if (!data || data.length === 0) {
        showError('This invite link is not valid.');
        return;
      }

      const trip = data[0];

      // Check 7-day expiry
      const created = new Date(trip.created_at);
      const now = new Date();
      const daysDiff = (now - created) / (1000 * 60 * 60 * 24);
      if (daysDiff > 7) {
        showError('This invite link has expired. Ask the host for a new one.');
        return;
      }

      tripId = trip.id;
      tripData = trip;
      $('#trip-name').textContent = trip.name;

      $('#loading').style.display = 'none';

      // Route based on trip status
      if (trip.status === 'revealed' || trip.status === 'planning' || trip.status === 'live' || trip.status === 'completed') {
        // Trip already decided
        const destName = trip.selected_destination || 'a destination';
        const destFlag = trip.selected_flag || '✈️';
        $('#revealed-dest').textContent = `${destFlag} ${destName}!`;
        $('#revealed-container').style.display = 'block';
        return;
      }

      if (trip.status === 'voting' && trip.trip_options && trip.trip_options.length > 0) {
        // Show voting UI
        $('#vote-trip-name').textContent = trip.name;
        tripOptions = trip.trip_options;
        $('#voting-container').style.display = 'block';
        return;
      }

      // Default: show preference form
      $('#form-container').style.display = 'block';
    } catch (e) {
      showError('Something went wrong. Please try again.');
    }
  }

  function showError(msg) {
    $('#loading').style.display = 'none';
    $('#error').style.display = 'block';
    $('#error-msg').textContent = msg;
  }

  // ── Populate destinations (called when Step 4 becomes visible) ──
  let destsPopulated = false;
  function populateDestinations() {
    if (destsPopulated) return;
    destsPopulated = true;
    const grid = $('#dest-grid');
    grid.innerHTML = '';
    (tripData.destination_shortlist || []).forEach((dest) => {
      const btn = document.createElement('button');
      btn.className = 'join-dest-btn';
      btn.type = 'button';
      btn.textContent = dest;
      btn.setAttribute('data-dest', dest);
      btn.style.cursor = 'pointer';
      btn.style.touchAction = 'manipulation';
      btn.addEventListener('click', function() {
        const isSelected = this.getAttribute('data-selected') === 'true';
        if (isSelected) {
          this.setAttribute('data-selected', 'false');
          this.style.borderColor = 'rgba(255,255,255,0.12)';
          this.style.background = '#171728';
          this.style.color = '#C0BCDA';
          this.textContent = dest;
          selectedDests = selectedDests.filter(d => d !== dest);
        } else {
          this.setAttribute('data-selected', 'true');
          this.style.borderColor = '#CCFF45';
          this.style.background = 'rgba(204,255,69,0.15)';
          this.style.color = '#CCFF45';
          this.textContent = dest + ' ✓';
          selectedDests.push(dest);
        }
      });
      grid.appendChild(btn);
    });
  }

  // ── Step navigation ────────────────────────────────────────
  function showStep(n) {
    step = n;
    for (let i = 1; i <= 5; i++) {
      const el = $(`#step-${i}`);
      if (el) el.style.display = i === n ? 'block' : 'none';
    }
    $('#back-btn').style.display = n > 1 ? 'inline-flex' : 'none';
    $('#next-btn').textContent = n === 5 ? 'Submit ✦' : 'Next →';
    $('#progress-bar').style.width = `${n * 20}%`;
    $('#step-label').textContent = `Step ${n} of 5`;

    // Populate destinations when Step 4 becomes visible
    if (n === 4 && tripData) populateDestinations();

    if (n === 5) buildSummary();
  }

  function buildSummary() {
    const nickname = $('#nickname').value.trim() || 'Anonymous';
    const bMin = $('#budget-min').value || '—';
    const bMax = $('#budget-max').value || '—';
    $('#summary').innerHTML = `
      <div class="join-summary-row"><span>Name</span><strong>${nickname} ${selectedEmoji}</strong></div>
      <div class="join-summary-row"><span>Budget</span><strong>$${bMin} – $${bMax}</strong></div>
      <div class="join-summary-row"><span>Vibes</span><strong>${selectedVibes.join(', ') || 'None'}</strong></div>
      <div class="join-summary-row"><span>Destinations</span><strong>${selectedDests.join(', ') || 'None'}</strong></div>
    `;
  }

  // ── Validation ─────────────────────────────────────────────
  function validateStep() {
    if (step === 1) {
      const name = $('#nickname').value.trim();
      if (!name) { alert('Enter your name or nickname.'); return false; }
    }
    if (step === 2) {
      const min = parseInt($('#budget-min').value);
      const max = parseInt($('#budget-max').value);
      if (isNaN(min) || isNaN(max)) { alert('Enter your budget range.'); return false; }
      if (min > max) { alert('Minimum budget cannot exceed maximum.'); return false; }
    }
    if (step === 3 && selectedVibes.length === 0) {
      alert('Pick at least one vibe.'); return false;
    }
    return true;
  }

  // ── Submit ─────────────────────────────────────────────────
  async function submitForm() {
    const nickname = $('#nickname').value.trim();
    const budgetMin = parseInt($('#budget-min').value) || 0;
    const budgetMax = parseInt($('#budget-max').value) || 0;

    $('#next-btn').textContent = 'Submitting...';
    $('#next-btn').disabled = true;

    try {
      // Check if member with this nickname already exists for this trip
      const checkRes = await fetch(
        `${SUPABASE_URL}/rest/v1/squad_members?trip_id=eq.${tripId}&nickname=eq.${encodeURIComponent(nickname)}&select=id`,
        { headers: { apikey: SUPABASE_ANON_KEY, Authorization: `Bearer ${SUPABASE_ANON_KEY}` } }
      );
      const existing = await checkRes.json();

      const memberData = {
        trip_id: tripId,
        nickname,
        emoji: selectedEmoji,
        role: 'member',
        status: 'submitted',
        vibes: selectedVibes,
        budget_min: budgetMin,
        budget_max: budgetMax,
        destination_prefs: selectedDests,
        responded_at: new Date().toISOString(),
      };

      let res;
      if (existing && existing.length > 0) {
        // Update existing member
        res = await fetch(`${SUPABASE_URL}/rest/v1/squad_members?id=eq.${existing[0].id}`, {
          method: 'PATCH',
          headers: {
            apikey: SUPABASE_ANON_KEY,
            Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
            'Content-Type': 'application/json',
            Prefer: 'return=minimal',
          },
          body: JSON.stringify(memberData),
        });
      } else {
        // Insert new member
        res = await fetch(`${SUPABASE_URL}/rest/v1/squad_members`, {
          method: 'POST',
          headers: {
            apikey: SUPABASE_ANON_KEY,
            Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
            'Content-Type': 'application/json',
            Prefer: 'return=minimal',
          },
          body: JSON.stringify(memberData),
        });
      }

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.message || 'Submission failed');
      }

      // Show success and start polling for voting
      $('#form-container').style.display = 'none';
      $('#success').style.display = 'block';
      // Show preferences as visual pills
      const prefsEl = $('#locked-prefs');
      if (prefsEl) {
        let pillsHtml = `<span class="locked-pill">${selectedEmoji} ${nickname}</span>`;
        selectedVibes.forEach(v => { pillsHtml += `<span class="locked-pill locked-pill-lime">${v}</span>`; });
        if ($('#budget-min').value) pillsHtml += `<span class="locked-pill">$${$('#budget-min').value}–$${$('#budget-max').value}</span>`;
        selectedDests.forEach(d => { pillsHtml += `<span class="locked-pill locked-pill-outline">${d}</span>`; });
        prefsEl.innerHTML = pillsHtml;
      }

      // Poll every 5 seconds to check if voting has started
      voteNickname = nickname;
      const pollInterval = setInterval(async () => {
        try {
          const pollRes = await fetch(
            `${SUPABASE_URL}/rest/v1/trips?invite_token=eq.${token}&select=status,trip_options(id,destination,country,flag,tagline,estimated_cost_pp,duration_days,vibe_match,compatibility_score,vote_count)`,
            { headers: { apikey: SUPABASE_ANON_KEY, Authorization: `Bearer ${SUPABASE_ANON_KEY}` } }
          );
          const pollData = await pollRes.json();
          if (pollData && pollData.length > 0 && pollData[0].status === 'voting' && pollData[0].trip_options && pollData[0].trip_options.length > 0) {
            clearInterval(pollInterval);
            tripOptions = pollData[0].trip_options;
            $('#success').style.display = 'none';
            $('#vote-trip-name').textContent = tripData.name;
            // Skip nickname step since we already have it
            $('#vote-nickname-step').style.display = 'none';
            renderVoteCards();
            $('#vote-options').style.display = 'block';
            $('#voting-container').style.display = 'block';
          }
        } catch (_) {}
      }, 3000);
    } catch (e) {
      alert('Something went wrong: ' + e.message);
      $('#next-btn').textContent = 'Submit ✦';
      $('#next-btn').disabled = false;
    }
  }

  // ── Event listeners ────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    loadTrip();

    // Emoji selection
    $$('.join-emoji-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        $$('.join-emoji-btn').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        selectedEmoji = btn.dataset.emoji;
      });
    });

    // Vibe selection (max 3)
    $$('.join-vibe-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const vibe = btn.dataset.vibe;
        if (btn.classList.contains('selected')) {
          btn.classList.remove('selected');
          selectedVibes = selectedVibes.filter(v => v !== vibe);
        } else if (selectedVibes.length < 3) {
          btn.classList.add('selected');
          selectedVibes.push(vibe);
        }
      });
    });

    // Custom destination
    $('#add-dest-btn').addEventListener('click', () => {
      const input = $('#custom-dest');
      const val = input.value.trim();
      if (!val) return;
      selectedDests.push(val);
      const btn = document.createElement('button');
      btn.className = 'join-dest-btn';
      btn.type = 'button';
      btn.textContent = val + ' ✓';
      btn.setAttribute('data-dest', val);
      btn.setAttribute('data-selected', 'true');
      btn.style.borderColor = '#CCFF45';
      btn.style.background = 'rgba(204,255,69,0.15)';
      btn.style.color = '#CCFF45';
      btn.style.cursor = 'pointer';
      btn.style.touchAction = 'manipulation';
      btn.addEventListener('click', function() {
        const isSelected = this.getAttribute('data-selected') === 'true';
        if (isSelected) {
          this.setAttribute('data-selected', 'false');
          this.style.borderColor = 'rgba(255,255,255,0.12)';
          this.style.background = '#171728';
          this.style.color = '#C0BCDA';
          this.textContent = val;
          selectedDests = selectedDests.filter(d => d !== val);
        } else {
          this.setAttribute('data-selected', 'true');
          this.style.borderColor = '#CCFF45';
          this.style.background = 'rgba(204,255,69,0.15)';
          this.style.color = '#CCFF45';
          this.textContent = val + ' ✓';
          selectedDests.push(val);
        }
      });
      $('#dest-grid').appendChild(btn);
      input.value = '';
    });

    // Next / Back
    $('#next-btn').addEventListener('click', () => {
      if (!validateStep()) return;
      if (step === 5) { submitForm(); return; }
      showStep(step + 1);
    });

    $('#back-btn').addEventListener('click', () => {
      if (step > 1) showStep(step - 1);
    });

    // ── Voting flow ──────────────────────────────────────────
    const nicknameBtn = $('#vote-nickname-btn');
    if (nicknameBtn) {
      nicknameBtn.addEventListener('click', () => {
        voteNickname = $('#vote-nickname').value.trim();
        if (!voteNickname) { alert('Enter your name.'); return; }
        $('#vote-nickname-step').style.display = 'none';
        renderVoteCards();
        $('#vote-options').style.display = 'block';
      });
    }

    const castBtn = $('#cast-vote-btn');
    if (castBtn) {
      castBtn.addEventListener('click', async () => {
        if (!selectedVoteOptionId) { alert('Pick a destination first.'); return; }
        castBtn.textContent = 'Submitting...';
        castBtn.disabled = true;
        try {
          // Check if member already exists, update status to voted
          const vCheckRes = await fetch(
            `${SUPABASE_URL}/rest/v1/squad_members?trip_id=eq.${tripId}&nickname=eq.${encodeURIComponent(voteNickname)}&select=id`,
            { headers: { apikey: SUPABASE_ANON_KEY, Authorization: `Bearer ${SUPABASE_ANON_KEY}` } }
          );
          const vExisting = await vCheckRes.json();

          if (vExisting && vExisting.length > 0) {
            // Update existing member status to voted
            await fetch(`${SUPABASE_URL}/rest/v1/squad_members?id=eq.${vExisting[0].id}`, {
              method: 'PATCH',
              headers: {
                apikey: SUPABASE_ANON_KEY,
                Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
                'Content-Type': 'application/json',
                Prefer: 'return=minimal',
              },
              body: JSON.stringify({ status: 'voted', responded_at: new Date().toISOString() }),
            });
          } else {
            // New voter who did not fill preferences
            await fetch(`${SUPABASE_URL}/rest/v1/squad_members`, {
              method: 'POST',
              headers: {
                apikey: SUPABASE_ANON_KEY,
                Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
                'Content-Type': 'application/json',
                Prefer: 'return=minimal',
              },
              body: JSON.stringify({
                trip_id: tripId,
                nickname: voteNickname,
                emoji: '😎',
                role: 'member',
                status: 'voted',
                vibes: [],
                budget_min: 0,
                budget_max: 0,
                destination_prefs: [],
                responded_at: new Date().toISOString(),
              }),
            });
          }
          // Atomically increment vote count via RPC
          if (selectedVoteOptionId) {
            await fetch(`${SUPABASE_URL}/rest/v1/rpc/increment_option_vote`, {
              method: 'POST',
              headers: {
                apikey: SUPABASE_ANON_KEY,
                Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({ option_id: selectedVoteOptionId }),
            });
          }
          $('#voting-container').style.display = 'none';
          $('#vote-success').style.display = 'block';
        } catch (e) {
          alert('Something went wrong: ' + e.message);
          castBtn.textContent = 'Cast my vote ✦';
          castBtn.disabled = false;
        }
      });
    }
  });

  function renderVoteCards() {
    const container = $('#vote-cards');
    container.innerHTML = '';
    tripOptions.forEach((opt) => {
      const card = document.createElement('div');
      card.className = 'vote-card';
      card.setAttribute('data-option-id', opt.id);
      card.innerHTML = `
        <div class="vote-card-top">
          <div class="vote-card-flag-big">${opt.flag || '🌍'}</div>
          <div class="vote-card-info">
            <div class="vote-card-dest">${opt.destination}, ${opt.country}</div>
            <div class="vote-card-tagline">${opt.tagline || ''}</div>
          </div>
          <div class="vote-card-check">✓</div>
        </div>
        ${opt.description ? `<div class="vote-card-desc">${opt.description}</div>` : ''}
        <div class="vote-card-pills">
          <span class="vote-pill">~$${opt.estimated_cost_pp || '?'}</span>
          <span class="vote-pill">${opt.duration_days || '?'} days</span>
          ${(opt.vibe_match || []).map(v => `<span class="vote-pill vote-pill-lime">${v}</span>`).join('')}
        </div>
        <div class="vote-card-compat">
          <span>squad compatibility</span>
          <span class="vote-card-pct">${Math.round((opt.compatibility_score || 0) * 100)}%</span>
        </div>
        <div class="vote-card-bar">
          <div class="vote-card-bar-fill" style="width:${(opt.compatibility_score || 0) * 100}%"></div>
        </div>
      `;
      card.style.cursor = 'pointer';
      card.style.touchAction = 'manipulation';
      card.onclick = function() {
        // Deselect all
        const allCards = container.querySelectorAll('.vote-card');
        allCards.forEach(function(c) {
          c.style.cssText = 'cursor:pointer; touch-action:manipulation; padding:20px; background:#171728; border:2px solid rgba(255,255,255,0.08); border-radius:18px; margin-bottom:14px; transition:all 0.25s;';
          const chk = c.querySelector('.vote-card-check');
          if (chk) chk.style.cssText = 'width:28px;height:28px;min-width:28px;max-width:28px;flex-shrink:0;border-radius:50%;border:2px solid rgba(255,255,255,0.12);background:transparent;color:transparent;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;line-height:1;';
          const dest = c.querySelector('.vote-card-dest');
          if (dest) dest.style.color = '#F0EDF8';
          const pct = c.querySelector('.vote-card-pct');
          if (pct) pct.style.color = '#9B6DFF';
          const bar = c.querySelector('.vote-card-bar-fill');
          if (bar) bar.style.background = '#9B6DFF';
        });
        // Select this one — full card highlight
        this.style.cssText = 'cursor:pointer; touch-action:manipulation; padding:20px; background:rgba(204,255,69,0.08); border:2px solid #CCFF45; border-radius:18px; margin-bottom:14px; box-shadow:0 4px 24px rgba(204,255,69,0.2); transform:scale(1.01); transition:all 0.25s;';
        const chk = this.querySelector('.vote-card-check');
        if (chk) chk.style.cssText = 'width:28px;height:28px;min-width:28px;max-width:28px;flex-shrink:0;border-radius:50%;border:2px solid #CCFF45;background:#CCFF45;color:#08080E;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;line-height:1;box-shadow:0 0 8px rgba(204,255,69,0.3);';
        const dest = this.querySelector('.vote-card-dest');
        if (dest) dest.style.color = '#CCFF45';
        const pct = this.querySelector('.vote-card-pct');
        if (pct) pct.style.color = '#CCFF45';
        const bar = this.querySelector('.vote-card-bar-fill');
        if (bar) bar.style.background = '#CCFF45';
        selectedVoteOptionId = opt.id;
      };
      container.appendChild(card);
    });
  }
</script>

