---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="TripSquad — The trip planner for the whole squad" description="AI-powered group travel planning. Vote on destinations, split costs, and actually go. By Afia Labs.">

<main class="landing">
  <div class="container">

    <!-- Hero -->
    <section class="hero">
      <div class="hero-badge">
        <span class="hero-dot"></span>
        Coming soon from Afia Labs
      </div>
      <h1>The trip planner for the <span class="accent">whole squad</span>.</h1>
      <p class="hero-sub">
        AI-powered group travel planning. Vote on destinations, match budgets anonymously, and actually go. No more dead group chats.
      </p>
      <div class="hero-features">
        <div class="hero-chip">🗳️ Democratic voting</div>
        <div class="hero-chip">🤖 AI trip generation</div>
        <div class="hero-chip">🔒 Anonymous budgets</div>
        <div class="hero-chip">📲 No download for squad</div>
      </div>
    </section>

    <!-- How it works -->
    <section class="how">
      <h2>How it works</h2>
      <div class="how-grid">
        <div class="how-card">
          <span class="how-num">01</span>
          <h3>Create a trip</h3>
          <p>Pick your vibes, set dates, shortlist destinations. Takes 2 minutes.</p>
        </div>
        <div class="how-card">
          <span class="how-num">02</span>
          <h3>Invite your squad</h3>
          <p>Share one link. They fill in preferences in their browser. No app needed.</p>
        </div>
        <div class="how-card">
          <span class="how-num">03</span>
          <h3>AI generates options</h3>
          <p>Claude builds 3 trip proposals matched to everyone's budget, vibes, and dates.</p>
        </div>
        <div class="how-card">
          <span class="how-num">04</span>
          <h3>Vote and go</h3>
          <p>The squad votes. The winner gets announced with a shareable reveal card.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta">
      <div class="cta-card">
        <h2>We are building this right now.</h2>
        <p>TripSquad launches soon. Follow Afia Labs for updates.</p>
        <a href="https://afialabs.net" target="_blank" rel="noopener noreferrer" class="landing-btn">
          Visit Afia Labs →
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <p>Afia Labs · Built with AI. Stayed in control. Owned the outcome.</p>
    </footer>

  </div>
</main>

</BaseLayout>

<style>
  .landing {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
  }

  .landing::before {
    content: '';
    position: absolute;
    top: -200px;
    left: -150px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(204, 255, 69, 0.1), transparent 70%);
    pointer-events: none;
  }

  .landing::after {
    content: '';
    position: absolute;
    top: 40%;
    right: -150px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(155, 109, 255, 0.08), transparent 70%);
    pointer-events: none;
  }

  .hero {
    padding: 140px 0 80px;
    text-align: center;
    position: relative;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border-radius: 999px;
    background: rgba(204, 255, 69, 0.08);
    border: 1px solid rgba(204, 255, 69, 0.2);
    font-size: 11px;
    font-weight: 700;
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 1.6px;
    color: var(--ts-lime);
    margin-bottom: 28px;
  }

  .hero-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ts-lime);
    box-shadow: 0 0 0 3px rgba(204, 255, 69, 0.2);
  }

  .hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(36px, 7vw, 56px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .accent { color: var(--ts-lime); }

  .hero-sub {
    font-size: 18px;
    line-height: 1.6;
    color: var(--ts-text2);
    max-width: 520px;
    margin: 0 auto 28px;
  }

  .hero-features {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
  }

  .hero-chip {
    padding: 8px 16px;
    background: var(--ts-s2);
    border: 1px solid var(--ts-border2);
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ts-text2);
  }

  .how {
    padding: 80px 0;
    position: relative;
  }

  .how h2 {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 800;
    text-align: center;
    margin-bottom: 40px;
    letter-spacing: -0.02em;
  }

  .how-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .how-card {
    padding: 28px 24px;
    background: var(--ts-s1);
    border: 1px solid var(--ts-border2);
    border-radius: 16px;
    transition: transform 0.2s, border-color 0.2s;
  }

  .how-card:hover {
    transform: translateY(-2px);
    border-color: rgba(204, 255, 69, 0.2);
  }

  .how-num {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 800;
    color: rgba(204, 255, 69, 0.2);
    display: block;
    margin-bottom: 8px;
  }

  .how-card h3 {
    font-family: var(--font-heading);
    font-size: 17px;
    font-weight: 800;
    margin-bottom: 6px;
  }

  .how-card p {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ts-text2);
  }

  .cta {
    padding: 60px 0 80px;
  }

  .cta-card {
    text-align: center;
    padding: 56px 40px;
    background: linear-gradient(135deg, rgba(204, 255, 69, 0.06), rgba(155, 109, 255, 0.06));
    border: 1px solid rgba(204, 255, 69, 0.15);
    border-radius: 24px;
  }

  .cta-card h2 {
    font-family: var(--font-heading);
    font-size: clamp(22px, 4vw, 30px);
    font-weight: 800;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .cta-card p {
    color: var(--ts-text2);
    font-size: 16px;
    margin-bottom: 24px;
  }

  .landing-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 700;
    border-radius: 999px;
    background: var(--ts-lime);
    color: var(--ts-bg);
    box-shadow: 0 8px 24px rgba(204, 255, 69, 0.25);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .landing-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(204, 255, 69, 0.35);
  }

  .footer {
    padding: 40px 0 48px;
    text-align: center;
    border-top: 1px solid var(--ts-border);
  }

  .footer p {
    font-size: 12px;
    font-weight: 600;
    color: var(--ts-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 600px) {
    .hero { padding: 100px 0 60px; }
    .how-grid { grid-template-columns: 1fr; }
    .cta-card { padding: 40px 24px; }
  }
</style>
