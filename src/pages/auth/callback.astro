---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Sign in complete — TripSquad">
<main class="landing" style="min-height:100vh; display:flex; align-items:center; justify-content:center;">
  <div style="text-align:center; padding:40px 24px;">
    <div style="font-size:64px; margin-bottom:16px;">✅</div>
    <h1 style="font-family:var(--font-heading); font-size:28px; font-weight:800; margin-bottom:8px; color:var(--ts-lime);">Signed in!</h1>
    <p style="color:var(--ts-text2); font-size:16px; max-width:360px; margin:0 auto 28px; line-height:1.6;">Tap below to go back to TripSquad.</p>
    <a id="open-app" href="#" style="display:inline-block; padding:16px 32px; background:#CCFF45; color:#08080E; font-family:var(--font-heading); font-size:16px; font-weight:700; border-radius:999px; text-decoration:none;">
      Open TripSquad →
    </a>
    <p style="color:var(--ts-muted); font-size:13px; margin-top:20px;">If the button does not work, open the TripSquad app manually.</p>
  </div>
</main>
</BaseLayout>

<script>
  // Build the deep link URL with auth data
  const hash = window.location.hash || '';
  const search = window.location.search || '';
  const params = hash || search;
  const deepLink = 'com.afialabs.tripsquad://login-callback' + params;

  // Set the button href
  const btn = document.getElementById('open-app');
  if (btn) btn.href = deepLink;

  // Also try automatic redirect
  try {
    window.location.href = deepLink;
  } catch (e) {
    // Ignore — button is the fallback
  }
</script>
